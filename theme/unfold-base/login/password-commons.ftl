<#macro logoutOtherSessions>
    <div id="kc-form-options" class="mb-5">
        <div class="flex items-center">
            <input type="checkbox" id="logout-sessions" name="logout-sessions" value="on" checked class="h-4 w-4 rounded border-base-300 text-primary-600 focus:ring-primary-600">
            <label for="logout-sessions" class="ml-2 block text-sm text-font-default-light dark:text-font-default-dark">${msg("logoutOtherSessions")}</label>
        </div>
    </div>
</#macro>
