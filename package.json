{
  "name": "keycloak-unfold-theme",
  "version": "26.0.0",
  "scripts": {
    "lint:css": "stylelint \"**/*.css\"",
    "build:css": "tailwind -i ./theme/unfold-base/login/resources/css/tailwind-input.css -o ./theme/unfold-base/login/resources/css/tailwind.css --minify",
    "build": "npm run build:css",
    "package": "npm run build && zip -r ${npm_package_name}-v${npm_package_version}.jar theme/ META-INF/"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "playwright": "^1.58.2",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.19"
  }
}
